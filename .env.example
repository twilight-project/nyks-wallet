# =============================================================================
# NYKS WALLET ENVIRONMENT CONFIGURATION
# =============================================================================
# This file contains all the environment variables needed to run the nyks-wallet application.
# Copy this file to .env and fill in the appropriate values for your environment.

# =============================================================================
# CORE CONFIGURATION
# =============================================================================
RUST_LOG=info,debug # Logging level for Rust applications (e.g., info, debug, trace)
RUST_BACKTRACE=full # Enable Rust backtrace for debugging
CHAIN_ID=nyks # The identifier for the blockchain network
NETWORK_TYPE=testnet # The type of network: testnet or mainnet
# =============================================================================
# NETWORK AND RPC ENDPOINTS
# =============================================================================
# These are the URLs for various services the wallet interacts with.

# ---------------------------------------------------------------------------
# Local development endpoints (uncomment for local dev)
# ---------------------------------------------------------------------------
# FAUCET_BASE_URL=http://0.0.0.0:6969
# NYKS_LCD_BASE_URL=http://0.0.0.0:1317
# NYKS_RPC_BASE_URL=http://0.0.0.0:26657
# RELAYER_API_RPC_SERVER_URL=http://0.0.0.0:8088/api
# PUBLIC_API_RPC_SERVER_URL=http://0.0.0.0:8088/api
# RELAYER_RPC_SERVER_URL=http://0.0.0.0:3032
# ZKOS_SERVER_URL=http://0.0.0.0:3030

# ---------------------------------------------------------------------------
# Testnet endpoints
# ---------------------------------------------------------------------------
# FAUCET_BASE_URL=https://faucet-rpc.twilight.rest
# NYKS_LCD_BASE_URL=https://lcd.twilight.rest
# NYKS_RPC_BASE_URL=https://rpc.twilight.rest
# RELAYER_API_RPC_SERVER_URL=https://relayer.twilight.rest/api
# ZKOS_SERVER_URL=https://nykschain.twilight.rest/zkos

# ---------------------------------------------------------------------------
# Mainnet endpoints (active)
# ---------------------------------------------------------------------------
NYKS_LCD_BASE_URL=https://lcd.twilight.org
NYKS_RPC_BASE_URL=https://rpc.twilight.org
RELAYER_API_RPC_SERVER_URL=https://api.ephemeral.fi/api
ZKOS_SERVER_URL=https://zkserver.twilight.org

# =============================================================================
# WALLET CONFIGURATION
# =============================================================================
RELAYER_PROGRAM_JSON_PATH=./relayerprogram.json # Path to the relayer program JSON file
NYKS_WALLET_PASSPHRASE=test1_password # Passphrase for the Nyks wallet, Leave empty if you want to use passphrase prompt
WALLET_ID= # Optional: Specify a wallet ID to use

# =============================================================================
# VALIDATOR-WALLET FEATURE
# =============================================================================
VALIDATOR_WALLET_PATH=validator-self.mnemonic # Path to the validator's mnemonic file

# =============================================================================
# DATABASE CONFIGURATION
# Required for the order-wallet feature, which is enabled by default.
# =============================================================================
DATABASE_URL_POSTGRESQL=postgresql://username:password@localhost:5432/database_name # Connection string for PostgreSQL
DATABASE_URL_SQLITE="./wallet_data.db" # Path to the SQLite database file


# =============================================================================
# NOTES
# =============================================================================
# 1. Ensure that all paths are correct for your system configuration.
# 2. For production environments, use secure passwords and manage keys carefully.
# 3. The local development URLs assume all services are running on the local machine.
